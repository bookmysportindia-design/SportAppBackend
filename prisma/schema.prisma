// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GROUND_OWNER
  GROUND_MANAGER

  CAPTAIN
  PLAYER

  TOURNAMENT_OWNER
  TOURNAMENT_ADMIN

  ACADEMY_OWNER
  TEAM_OWNER
}

enum Amenity {
  PARKING 
  TOILETS
  CHANGING_ROOMS
  FIRST_AID
  WATER_FACILITY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PAID
  REFUNDED
}

enum Slot {
  PRE_DAWN
  SLOT1
  SLOT2
  SLOT3
  DNSLOT
  MIDNIGHT
}

enum Sport {
  CRICKET
  FOOTBALL
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum InviteType {
  INVITE        // captain → player
  JOIN_REQUEST  // player → team (captain responds)
}

enum EntityType {
  TEAM
  TOURNAMENT
  VENUE
}

model User {
  id              String   @id @default(uuid())
  phone           String   @unique
  name            String?
  email           String?  @unique
  profilePicture  String?

  roles           Role[]
  memberships     Membership[]

  venues          Venue[]  @relation("OwnerVenues")
  bookings        Booking[] 
  notifications   Notification[]
  favorites       Favorite[]

  teams           Team[]   @relation("CaptainTeams")
  initiatedInvites TeamInvite[] @relation("InitiatedInvites")
  receivedInvites  TeamInvite[] @relation("ReceivedInvites")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Venue {
  id            String   @id @default(uuid())
  name          String
  contactNumber String
  city          String
  address       String
  latitude      Float?
  longitude     Float?
  openingTime   String
  closingTime   String
  workingDays   String[]
  sportTypes    String[]
  amenities     Amenity[]
  photos        String[]

  // Remove ownerId and owner relation if you want to allow multiple owners/managers per venue
  ownerId       String
  owner         User     @relation("OwnerVenues", fields: [ownerId], references: [id])

  bookings      Booking[]
  favoritedBy   Favorite[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Otp {
  id          String   @id @default(uuid())
  phone       String
  otpHash     String
  expiresAt   DateTime
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([phone])
}

model Booking {
  id              String         @id @default(uuid())
  referenceNumber String         @unique
  bookingDate     DateTime
  slot            Slot
  sport           Sport
  playersPerTeam  Int

  baseAmount      Int            // original price
  discountAmount  Int            @default(0)
  totalAmount     Int

  appliedOfferCode String?       // "PLAY20"
  appliedOfferTitle String?      // "20% off"

  paymentStatus   PaymentStatus  @default(PAID)
  status          BookingStatus  @default(CONFIRMED)

  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  venueId         String
  venue           Venue          @relation(fields: [venueId], references: [id])

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  cancelledAt     DateTime?

  @@index([userId])
  @@index([venueId])
  @@index([bookingDate])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id],onDelete: Cascade)
  title       String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  venueId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, venueId]) // Prevents a user from favoriting the same venue twice
  @@index([userId])
  @@index([venueId])
}

model Team {
  id            String       @id @default(uuid())
  name          String
  city          String
  sport         Sport
  primaryGround String?

  captainId     String
  captain       User         @relation("CaptainTeams", fields: [captainId], references: [id])

  invites       TeamInvite[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model TeamInvite {
  id          String       @id @default(uuid())
  type        InviteType
  status      InviteStatus @default(PENDING)

  teamId      String
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // who created this record (captain for INVITE, player for JOIN_REQUEST)
  initiatorId String
  initiator   User         @relation("InitiatedInvites", fields: [initiatorId], references: [id], onDelete: Cascade)

  // who needs to respond (player for INVITE, captain for JOIN_REQUEST)
  recipientId String
  recipient   User         @relation("ReceivedInvites", fields: [recipientId], references: [id], onDelete: Cascade)

  expiresAt   DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([teamId])
  @@index([initiatorId])
  @@index([recipientId])
}

model Membership {
  id          String      @id @default(uuid())

  userId      String
  entityId    String
  entityType  EntityType
  role        Role

  user        User        @relation(fields: [userId], references: [id],onDelete: Cascade)

  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([entityId, entityType])
  @@unique([userId, entityId, entityType, role])
}